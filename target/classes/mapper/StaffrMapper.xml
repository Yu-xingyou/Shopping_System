<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xingyou.mapper.StaffMapper">

    <select id="findById" resultType="com.xingyou.entity.people.Staff">
        SELECT * FROM staff WHERE staff_id = #{staffId}
    </select>

    <select id="findByName" resultType="com.xingyou.entity.people.Staff">
        SELECT * FROM staff WHERE name = #{name}
    </select>

    <select id="findAllUsers" resultType="com.xingyou.entity.people.User">
        SELECT * FROM user ORDER BY user_id DESC
    </select>

    <select id="findUserByUserId" resultType="com.xingyou.entity.people.User">
        SELECT * FROM user WHERE user_id = #{userId}
    </select>

    <select id="findUserByName" resultType="com.xingyou.entity.people.User">
        SELECT * FROM user WHERE name LIKE CONCAT('%', #{name}, '%') ORDER BY user_id DESC
    </select>
</mapper>