<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    收藏数据访问层映射文件
    提供收藏记录的查询、插入和删除等数据库操作
-->
<mapper namespace="com.xingyou.mapper.FavoriteMapper">

    <!-- 根据用户ID查询收藏列表，按创建时间降序排列 -->
    <select id="findByUserId" resultType="com.xingyou.entity.shopping.Favorite">
        SELECT * FROM favorite WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>

    <!-- 根据用户ID和商品ID查询收藏记录 -->
    <select id="findByUserIdAndProductId" resultType="com.xingyou.entity.shopping.Favorite">
        SELECT * FROM favorite WHERE user_id = #{userId} AND product_id = #{productId}
    </select>

    <!-- 根据商品ID查询所有收藏了该商品的用户记录，按创建时间降序排列 -->
    <select id="findByProductId" resultType="com.xingyou.entity.shopping.Favorite">
        SELECT * FROM favorite WHERE product_id = #{productId} ORDER BY create_time DESC
    </select>

    <!-- 插入收藏记录 -->
    <insert id="insert" parameterType="com.xingyou.entity.shopping.Favorite">
        INSERT INTO favorite (user_id, product_id)
        VALUES (#{userId}, #{productId})
    </insert>

    <!-- 删除收藏记录 -->
    <delete id="deleteByUserIdAndProductId">
        DELETE FROM favorite WHERE user_id = #{userId} AND product_id = #{productId}
    </delete>
</mapper>
