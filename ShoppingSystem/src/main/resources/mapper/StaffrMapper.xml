<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xingyou.mapper.StaffMapper">

    <insert id="insert" parameterType="com.xingyou.entity.people.Staff">
        INSERT INTO staff (staff_id, name, password, status)
        VALUES (#{staffId}, #{name}, #{password}, #{status})
    </insert>

    <select id="findByStaffId" resultType="com.xingyou.entity.people.Staff">
        SELECT * FROM staff WHERE staff_id = #{staffId}
    </select>

    <select id="findById" resultType="com.xingyou.entity.people.Staff">
        SELECT * FROM staff WHERE staff_id = #{staffId}
    </select>

    <select id="findAllUsers" resultType="com.xingyou.entity.people.User">
        SELECT * FROM user
    </select>

    <select id="findUserByUserId" resultType="com.xingyou.entity.people.User">
        SELECT * FROM user WHERE user_id = #{userId}
    </select>

    <select id="findUserByName" resultType="com.xingyou.entity.people.User">
        SELECT * FROM user WHERE name LIKE CONCAT('%', #{name}, '%')
    </select>

    <update id="update" parameterType="com.xingyou.entity.people.Staff">
        UPDATE staff
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="password != null">password = #{password},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE staff_id = #{staffId}
    </update>
</mapper>