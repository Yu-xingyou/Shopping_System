<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xingyou.mapper.OrderMapper">

    <insert id="insert" parameterType="com.xingyou.entity.shopping.Order" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `order` (
            order_num, 
            user_id, 
            total_amount, 
            status, 
            receiver_name, 
            receiver_phone, 
            receiver_address,
            remark,
            create_time
        ) VALUES (
            #{orderNum}, 
            #{userId}, 
            #{totalAmount}, 
            #{status}, 
            #{receiverName}, 
            #{receiverPhone}, 
            #{receiverAddress},
            #{remark},
            #{createTime}
        )
    </insert>

    <insert id="insertOrderItem" parameterType="com.xingyou.entity.shopping.OrderItem">
        INSERT INTO order_item (
            order_id, 
            product_id, 
            product_name, 
            product_price, 
            quantity
        ) VALUES (
            #{orderId}, 
            #{productId}, 
            #{productName}, 
            #{productPrice}, 
            #{quantity}
        )
    </insert>

    <select id="findAll" resultType="com.xingyou.entity.shopping.Order">
        SELECT * FROM `order` ORDER BY create_time DESC
    </select>

    <select id="findById" resultType="com.xingyou.entity.shopping.Order">
        SELECT * FROM `order` WHERE id = #{id}
    </select>

    <select id="findByUserId" resultType="com.xingyou.entity.shopping.Order">
        SELECT * FROM `order` WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>

    <select id="findOrderItemsByOrderId" resultType="com.xingyou.entity.shopping.OrderItem">
        SELECT * FROM order_item WHERE order_id = #{orderId}
    </select>

    <update id="updateStatus">
        UPDATE `order`
        SET status = #{status}
        WHERE id = #{id}
    </update>

    <update id="updateUserMoney">
        UPDATE user SET money = money + #{money} WHERE user_id = #{userId}
    </update>

    <select id="findUserByUserId" resultType="com.xingyou.entity.people.User">
        SELECT * FROM user WHERE user_id = #{userId}
    </select>

    <update id="updateProductStock">
        UPDATE product SET stock = stock - #{quantity} WHERE id = #{productId} AND stock >= #{quantity}
    </update>

    <select id="findProductById" resultType="com.xingyou.entity.shopping.Product">
        SELECT * FROM product WHERE id = #{id}
    </select>
</mapper>
