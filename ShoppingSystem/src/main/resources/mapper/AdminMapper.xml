<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    管理员数据访问层映射文件

    提供管理员相关的数据库操作，包括管理员登录、信息管理，
    以及管理员对用户、员工、订单的管理功能。
-->
<mapper namespace="com.xingyou.mapper.AdminMapper">

    <!-- 新增管理员 -->
    <insert id="insert" parameterType="com.xingyou.entity.people.User">
        INSERT INTO admin (admin_id, name, password)
        VALUES (#{userId}, #{name}, #{password})
    </insert>

    <!-- 根据管理员ID查询管理员信息 -->
    <select id="findByAdminId" resultType="com.xingyou.entity.people.User">
        SELECT
            admin_id AS userId,
            name,
            password,
            email,
            phone,
            avatar,
            status,
            2 AS role
        FROM admin
        WHERE admin_id = #{adminId}
    </select>

    <!-- 查询所有用户列表（管理员权限） -->
    <select id="findAllUsers" resultType="com.xingyou.entity.people.User">
        SELECT * FROM user
    </select>

    <!-- 根据用户ID查询用户信息 -->
    <select id="findUserByUserId" resultType="com.xingyou.entity.people.User">
        SELECT * FROM user WHERE user_id = #{userId}
    </select>

    <!-- 根据用户名模糊查询用户 -->
    <select id="findUserByName" resultType="com.xingyou.entity.people.User">
        SELECT * FROM user WHERE name LIKE CONCAT('%', #{name}, '%')
    </select>

    <!-- 查询所有员工列表（管理员权限） -->
    <select id="findAllStaffs" resultType="com.xingyou.entity.people.User">
        SELECT
            staff_id AS userId,
            name,
            password,
            email,
            phone,
            avatar,
            status,
            1 AS role
        FROM staff
    </select>

    <!-- 根据员工ID查询员工信息 -->
    <select id="findStaffByStaffId" resultType="com.xingyou.entity.people.User">
        SELECT
            staff_id AS userId,
            name,
            password,
            email,
            phone,
            avatar,
            status,
            1 AS role
        FROM staff
        WHERE staff_id = #{staffId}
    </select>

    <!-- 根据员工姓名模糊查询员工 -->
    <select id="findStaffByName" resultType="com.xingyou.entity.people.User">
        SELECT
            staff_id AS userId,
            name,
            password,
            email,
            phone,
            avatar,
            status,
            1 AS role
        FROM staff
        WHERE name LIKE CONCAT('%', #{name}, '%')
    </select>

    <!-- 查询所有订单列表（管理员权限） -->
    <select id="findAllOrders" resultType="com.xingyou.entity.shopping.Order">
        SELECT * FROM `order`
    </select>

    <!-- 新增员工 -->
    <insert id="addStaff" parameterType="com.xingyou.entity.people.User">
        INSERT INTO staff (staff_id, name, password, email, phone, avatar, status, role)
        VALUES (#{userId}, #{name}, #{password}, #{email}, #{phone}, #{avatar}, #{status}, #{role})
    </insert>

    <!--
        选择性更新员工信息

        只更新提供的非空字段，未提供的字段保持原值不变。
        支持更新姓名、密码、邮箱、手机、头像、状态等字段。
    -->
    <update id="updateStaff" parameterType="com.xingyou.entity.people.User">
        UPDATE staff
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="password != null">password = #{password},</if>
            <if test="email != null">email = #{email},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE staff_id = #{userId}
    </update>

    <!-- 更新商品库存（直接设置库存值） -->
    <update id="updateProductStock">
        UPDATE product
        SET stock = #{stock}
        WHERE id = #{id}
    </update>

    <!--
        选择性更新管理员信息

        只更新提供的非空字段，未提供的字段保持原值不变。
        支持更新姓名、密码、邮箱、手机、头像等字段。
    -->
    <update id="update" parameterType="com.xingyou.entity.people.User">
        UPDATE admin
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="password != null">password = #{password},</if>
            <if test="email != null">email = #{email},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
        </set>
        WHERE admin_id = #{userId}
    </update>

    <!--
        查询已完成订单的总收益（按收货时间范围筛选）

        只统计状态为3（已完成/已收货）的订单总金额。
        根据days参数按收货时间（finish_time）筛选时间范围：
        - null: 查询全部
        - 1: 1天内
        - 7: 7天内
        - 30: 一个月内
    -->
    <select id="getTotalRevenue" resultType="java.lang.Double">
        SELECT IFNULL(SUM(total_amount), 0)
        FROM `order`
        WHERE status = 3
        <if test="days != null">
            AND finish_time >= DATE_SUB(NOW(), INTERVAL #{days} DAY)
        </if>
    </select>

    <!-- 查询所有管理员列表 -->
    <select id="findAllAdmins" resultType="com.xingyou.entity.people.User">
        SELECT
            admin_id AS userId,
            name,
            password,
            email,
            phone,
            avatar,
            status,
            2 AS role
        FROM admin
    </select>
</mapper>
