<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xingyou.mapper.ProductMapper">

    <select id="findAll" resultType="com.xingyou.entity.shopping.Product">
        SELECT * FROM product
    </select>

    <select id="findByCondition" resultType="com.xingyou.entity.shopping.Product">
        SELECT * FROM product
        <where>
            <if test="product.id != null">
                AND id = #{product.id}
            </if>
            <if test="product.name != null and product.name.trim() != ''">
                AND name LIKE CONCAT('%', #{product.name}, '%')
            </if>
        </where>
    </select>

    <select id="findById" resultType="com.xingyou.entity.shopping.Product">
        SELECT * FROM product WHERE id = #{id}
    </select>
</mapper>
